<Window
    x:Class="Lab3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Lab3"
    xmlns:views="using:Lab3.Views"
    Title="Lab3: Стеганография + Рюкзак">

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Стеганография" Tag="Stego" />
                <NavigationViewItem Content="Шифрование рюкзаком" Tag="Knapsack"/>
                <NavigationViewItem Content="RSA" Tag="RSA"/>
                <NavigationViewItem Content="Отладка" Tag="Logs"/>
                <NavigationViewItem Content="Стегоанализ" Tag="StegoAnalysis"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>