<Application
    x:Class="Lab3.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Lab3"
    xmlns:converters="using:Lab3.Converters"
    xmlns:vm="using:Lab3.ViewModels">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NotEmptyToBoolConverter x:Key="NotEmptyToBoolConverter" />
            <converters:IntToDoubleConverter x:Key="IntToDoubleConverter" />
            <converters:PercentToWidthConverter x:Key="PercentToWidthConverter" />
            <converters:LogColorConverter x:Key="LogColorConverter"/>
            <converters:PercentToHeightConverter x:Key="PercentToHeightConverter"/>
            <converters:BoolToTextConverter x:Key="BoolToTextConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <converters:FillToOffsetConverter x:Key="FillToOffsetConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>