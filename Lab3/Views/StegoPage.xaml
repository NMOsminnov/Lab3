<Page
    x:Class="Lab3.Views.StegoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Lab3.ViewModels">


    <ScrollViewer Padding="20">
        <StackPanel Spacing="15" MaxWidth="800">
            <TextBlock Text="Стеганография (LSB)" Style="{StaticResource SubheaderTextBlockStyle}" />

            <!-- Настройки бит -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Бит на канал:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{x:Bind ViewModel.BitsOptions}" 
                         SelectedValue="{x:Bind ViewModel.BitsPerChannel, Mode=TwoWay}"
                         Width="100" />
            </StackPanel>

            <!-- Выбор изображения -->
            <StackPanel Spacing="5">
                <Button Content="Выбрать изображение" Command="{x:Bind ViewModel.SelectImageCommand}" />
                <Image x:Name="PreviewImage" 
                       Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}" 
                       MaxHeight="300" Stretch="Uniform" />
            </StackPanel>

<Expander Header="Предварительное шифрование (Шифр Хилла)" IsExpanded="True">
    <StackPanel Spacing="10" Margin="0,10,0,0">
        <CheckBox Content="Использовать шифр Хилла" 
                  IsChecked="{x:Bind ViewModel.UseHillCipher, Mode=TwoWay}"/>

        <!-- 🔥 IsEnabled привязан к каждому контролу отдельно. Это компилируется без ошибок -->
        <StackPanel Spacing="10" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Размер матрицы:" VerticalAlignment="Center" Width="100"/>
                
                <ComboBox ItemsSource="{x:Bind ViewModel.HillKeySizeOptions}"
                          SelectedValue="{x:Bind ViewModel.HillKeySize, Mode=TwoWay}"
                          Width="60"
                          IsEnabled="{x:Bind ViewModel.UseHillCipher, Mode=OneWay}"/>
                          
                <Button Content="Сгенерировать" Command="{x:Bind ViewModel.GenerateHillKeyCommand}" Width="120"
                        IsEnabled="{x:Bind ViewModel.UseHillCipher, Mode=OneWay}"/>
                <Button Content="Экспорт" Command="{x:Bind ViewModel.ExportHillKeyCommand}" Width="80"
                        IsEnabled="{x:Bind ViewModel.UseHillCipher, Mode=OneWay}"/>
                <Button Content="Импорт" Command="{x:Bind ViewModel.ImportHillKeyCommand}" Width="80"
                        IsEnabled="{x:Bind ViewModel.UseHillCipher, Mode=OneWay}"/>
            </StackPanel>

            <TextBox Header="Матрица ключа"
                     Text="{x:Bind ViewModel.HillKeyDisplay, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     MinHeight="80"
                     VerticalContentAlignment="Top"
                     IsEnabled="{x:Bind ViewModel.UseHillCipher, Mode=OneWay}"/>
            
            <TextBlock Text="Формат: a, b; c, d (строки разделены точкой с запятой)" 
                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
        </StackPanel>
    </StackPanel>
</Expander>

<Expander Header="Лабораторная 5: Целостность и Хэмминг" IsExpanded="False">
    <StackPanel Spacing="10" Margin="0,10,0,0">
        <CheckBox Content="Использовать код Хэмминга (7,4)" 
                  IsChecked="{x:Bind ViewModel.UseHammingCode, Mode=TwoWay}"/>
        
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
            <Button Content="Исказить изображение" Command="{x:Bind ViewModel.ApplyDistortionCommand}" Width="150"/>
            <NumberBox Header="Кол-во ошибок:" 
                       Value="{x:Bind ViewModel.DistortionErrorCount, Mode=TwoWay}" 
                       Minimum="0" Maximum="10000" Width="120"/>
        </StackPanel>
        
        <TextBlock Text="Статус целостности:" FontWeight="SemiBold"/>
        <TextBlock Text="{x:Bind ViewModel.IntegrityStatus, Mode=OneWay}" 
                   Foreground="{x:Bind ViewModel.IntegrityColor, Mode=OneWay}"/>
    </StackPanel>
</Expander>

            <!-- Ввод текста -->
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Загрузить из файла" Command="{x:Bind ViewModel.LoadTextFromFileCommand}" />
                    <Button Content="Сохранить результат" Command="{x:Bind ViewModel.SaveImageCommand}" />
                </StackPanel>
                <TextBox Header="Текст для внедрения" 
                        Text="{x:Bind ViewModel.InputText, Mode=TwoWay}"
                        AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
            </StackPanel>

            <!-- Кнопки действий -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Внедрить текст" Command="{x:Bind ViewModel.EmbedTextCommand}" 
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <Button Content="Извлечь текст" Command="{x:Bind ViewModel.ExtractTextCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
            </StackPanel>

            <!-- Результат извлечения -->
            <StackPanel Spacing="5">
                <TextBlock Text="Извлечённый текст:" FontWeight="SemiBold" />
                <TextBox Text="{x:Bind ViewModel.ExtractedText, Mode=OneWay}" 
                        IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
                <Button Content="Сохранить текст" Command="{x:Bind ViewModel.SaveExtractedTextCommand}" 
                        HorizontalAlignment="Right" />
            </StackPanel>

            <Button Content="🧪 Тест Хэмминга" Command="{x:Bind ViewModel.TestHammingCommand}" />

            <!-- Статус -->
            <InfoBar Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                    IsOpen="{x:Bind ViewModel.StatusMessage, Converter={StaticResource NotEmptyToBoolConverter}}" />
        </StackPanel>
    </ScrollViewer>
</Page>