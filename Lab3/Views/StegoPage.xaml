<Page
    x:Class="Lab3.Views.StegoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Lab3.ViewModels">


    <ScrollViewer Padding="20">
        <StackPanel Spacing="15" MaxWidth="800">
            <TextBlock Text="Стеганография (LSB)" Style="{StaticResource SubheaderTextBlockStyle}" />

            <!-- Настройки бит -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Бит на канал:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{x:Bind ViewModel.BitsOptions}" 
                         SelectedValue="{x:Bind ViewModel.BitsPerChannel, Mode=TwoWay}"
                         Width="100" />
            </StackPanel>

            <!-- Выбор изображения -->
            <StackPanel Spacing="5">
                <Button Content="Выбрать изображение" Command="{x:Bind ViewModel.SelectImageCommand}" />
                <Image x:Name="PreviewImage" 
                       Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}" 
                       MaxHeight="300" Stretch="Uniform" />
            </StackPanel>

            <!-- Ввод текста -->
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Загрузить из файла" Command="{x:Bind ViewModel.LoadTextFromFileCommand}" />
                    <Button Content="Сохранить результат" Command="{x:Bind ViewModel.SaveImageCommand}" />
                </StackPanel>
                <TextBox Header="Текст для внедрения" 
                        Text="{x:Bind ViewModel.InputText, Mode=TwoWay}"
                        AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
            </StackPanel>

            <!-- Кнопки действий -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Внедрить текст" Command="{x:Bind ViewModel.EmbedTextCommand}" 
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <Button Content="Извлечь текст" Command="{x:Bind ViewModel.ExtractTextCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
            </StackPanel>

            <!-- Результат извлечения -->
            <StackPanel Spacing="5">
                <TextBlock Text="Извлечённый текст:" FontWeight="SemiBold" />
                <TextBox Text="{x:Bind ViewModel.ExtractedText, Mode=OneWay}" 
                        IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
                <Button Content="Сохранить текст" Command="{x:Bind ViewModel.SaveExtractedTextCommand}" 
                        HorizontalAlignment="Right" />
            </StackPanel>

            <!-- Статус -->
            <InfoBar Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                    IsOpen="{x:Bind ViewModel.StatusMessage, Converter={StaticResource NotEmptyToBoolConverter}}" />
        </StackPanel>
    </ScrollViewer>
</Page>